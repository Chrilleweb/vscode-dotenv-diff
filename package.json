{
  "name": "dotenv-diff",
  "displayName": "Dotenv-diff",
  "description": "Catch missing and unused environment variables against your .env file",
  "version": "0.6.8",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Linters"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:typescript",
    "onLanguage:javascript",
    "workspaceContains:**/.env"
  ],
  "contributes": {},
  "sideEffects": false,
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "prepare": "husky",
    "lint-staged": "lint-staged",
    "test": "vscode-test",
    "release": "release-it",
    "release:dry": "release-it --dry-run"
  },
  "author": "Chrilleweb",
  "publisher": "Chrilleweb",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Chrilleweb/vscode-dotenv-diff.git"
  },
  "bugs": {
    "url": "https://github.com/Chrilleweb/vscode-dotenv-diff/issues"
  },
  "icon": "images/logo.png",
  "lint-staged": {
    "*.{ts,js}": [
      "prettier --write",
      "eslint --fix --max-warnings=0"
    ],
    "*.{json,yml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@release-it/conventional-changelog": "^11.0.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "~26.1.1",
    "@types/vscode": "^1.125.0",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0",
    "eslint": "^10.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.5",
    "release-it": "^20.2.1",
    "typescript": "^7.0.2",
    "typescript-eslint": "^8.63.0"
  }
}
